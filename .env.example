# OndoREDashboard — copy to .env and fill in values.

# IMPORTANT: .env was accidentally committed in earlier git history.
# If this is a public repo, purge it with: git filter-repo --invert-paths --path .env
# then force-push. Rotate all credential values below before using in production.

# API base URL (no trailing slash). Login and all API calls use this.
# Local dev: run OndoREBackend (`npm run dev`). Default PORT is 3030 (see OndoREBackend/.env.example).
# Production / deployed dashboard: use your Supabase Edge Function URL.
# VITE_API_BASE_URL=https://<project-ref>.supabase.co/functions/v1/api
VITE_API_BASE_URL=http://localhost:3030/api

# Prod-like local (behind dev-proxy): API at api.localhost:3000
# VITE_API_BASE_URL=http://api.localhost:3000/api

# Stripe (publishable key only — secret key is backend-only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Supabase Realtime (for live dashboard updates)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Test accounts for local dev only (never set in production)
VITE_TEST_OWNER_EMAIL=test-owner@example.com
VITE_TEST_TENANT_EMAIL=test-tenant@example.com
VITE_TEST_PASSWORD=change-me
