# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Supabase Realtime (for live dashboard updates)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API Base URL
VITE_API_BASE_URL=http://localhost:3030/api

# Demo login helper (shown in local dev and any deployment with VITE_ENABLE_PUBLIC_DEMO=true)
VITE_TEST_OWNER_EMAIL=owner@example.com
VITE_TEST_TENANT_EMAIL=tenant@example.com
VITE_DEMO_PASSWORD=demo-password-here
VITE_ENABLE_PUBLIC_DEMO=false
