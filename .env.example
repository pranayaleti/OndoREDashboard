# OndoREDashboard — copy to .env and fill in values.

# API Configuration — Supabase Edge Function
# Format: https://<project-ref>.supabase.co/functions/v1/api
VITE_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1/api

# Stripe (publishable key only — secret key is backend-only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Supabase Realtime (for live dashboard updates)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Test accounts for local dev only (never set in production)
VITE_TEST_OWNER_EMAIL=test-owner@example.com
VITE_TEST_TENANT_EMAIL=test-tenant@example.com
VITE_TEST_PASSWORD=Test@123
